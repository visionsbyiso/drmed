# Server
PORT=8080
JSON_BODY_LIMIT=20mb
ALLOWED_ORIGIN=https://drmed.ph,https://www.drmed.ph,http://localhost:5500,http://127.0.0.1:5500

# Google resources
SHEET_ID=1O09S6_hRv-c7irI_HJtbYraWSXQs08IET0-bqQIWQh4
SHEET_NAME=Sheet1
# Storage mode: drive or local
RESULT_STORAGE=drive
# Used when RESULT_STORAGE=local
LOCAL_RESULTS_DIR=./uploaded-results
# Used when RESULT_STORAGE=drive
DRIVE_FOLDER_ID=PUT_YOUR_PRIVATE_DRIVE_FOLDER_ID_HERE
# Drive auth mode: service_account (default) or oauth_user
DRIVE_AUTH_MODE=service_account

# Portal security
REQUIRE_PORTAL_CONSENT=true
REQUIRE_PORTAL_CAPTCHA=true
TURNSTILE_SECRET_KEY=REPLACE_WITH_REAL_TURNSTILE_SECRET
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# Consent audit trail
ENABLE_CONSENT_AUDIT_LOG=true
CONSENT_NOTICE_VERSION=2026-02-24
CONSENT_LOG_FILE=./logs/portal-consent.ndjson
CONSENT_LOG_TO_SHEETS=false
CONSENT_LOG_SHEET_NAME=ConsentLogs

# Short-lived portal session token returned by /api/portal/verify
PORTAL_ACCESS_TOKEN_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
PORTAL_ACCESS_TOKEN_TTL_SECONDS=900

# Staff upload API (user ID + password only)
# Staff gate credentials (JSON map: user -> password or scrypt hash)
# Example (plain): {"frontdesk-1":"StrongPass123!","lab-1":"AnotherStrongPass!"}
# Example (hash): {"frontdesk-1":"scrypt$16384$8$1$<salt-b64>$<hash-b64>"}
STAFF_GATE_USERS_JSON={"frontdesk-1":"REPLACE_WITH_PASSWORD"}
STAFF_SESSION_TOKEN_SECRET=REPLACE_WITH_LONG_RANDOM_STAFF_SESSION_SECRET
STAFF_SESSION_TTL_SECONDS=43200
MAX_STAFF_PDF_BYTES=12582912
MAX_STAFF_BULK_ITEMS=25
ENABLE_STAFF_AUDIT_LOG=true
STAFF_AUDIT_LOG_FILE=./logs/staff-audit.ndjson
AUDIT_LOG_MAX_BYTES=5242880
AUDIT_LOG_MAX_DAYS=30

# Staff lockout controls
STAFF_LOCKOUT_MAX_ATTEMPTS=5
STAFF_LOCKOUT_WINDOW_MS=900000
STAFF_LOCKOUT_DURATION_MS=900000
STAFF_LOCKOUT_SCOPE=user_ip

# Optional MFA (TOTP)
# Provide per-user base32 secrets (JSON map: user -> secret)
# Example: {"frontdesk-1":"JBSWY3DPEHPK3PXP"}
STAFF_MFA_REQUIRED=false
STAFF_MFA_SECRETS_JSON={}

# Option A (recommended for local dev): path to Service Account key file
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account-key.json
#
# Option A: Local/dev or non-GCP hosting (JSON key as one-line JSON string)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option B (recommended if service account has no Drive upload quota): OAuth user token for Drive uploads
# Keep Sheets on service account, Drive on OAuth user.
# Set DRIVE_AUTH_MODE=oauth_user and these values:
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8085/oauth2/callback
# GOOGLE_OAUTH_REFRESH_TOKEN=

# Option B (recommended on GCP Cloud Run):
# Do not set GOOGLE_SERVICE_ACCOUNT_JSON.
# Attach a service account to Cloud Run with Sheets/Drive read permissions.
