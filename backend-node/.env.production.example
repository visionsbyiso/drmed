# =========================
# DRMed PRODUCTION PROFILE
# Security + RA 10173 baseline
# =========================

# Server
NODE_ENV=production
STRICT_SECURITY_MODE=true
PORT=8080
JSON_BODY_LIMIT=20mb
ALLOWED_ORIGIN=https://drmed.ph,https://www.drmed.ph

# Google resources
SHEET_ID=REPLACE_WITH_PROD_SHEET_ID
SHEET_NAME=Sheet1
RESULT_STORAGE=drive
DRIVE_FOLDER_ID=REPLACE_WITH_PRIVATE_DRIVE_FOLDER_ID
# Drive auth mode: service_account or oauth_user
DRIVE_AUTH_MODE=oauth_user
# Use these only when RESULT_STORAGE=local:
# LOCAL_RESULTS_DIR=/var/data/results

# Portal security
REQUIRE_PORTAL_CONSENT=true
REQUIRE_PORTAL_CAPTCHA=true
TURNSTILE_SECRET_KEY=REPLACE_WITH_TURNSTILE_SECRET
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# Consent audit trail (keep enabled)
ENABLE_CONSENT_AUDIT_LOG=true
CONSENT_NOTICE_VERSION=2026-03-08
CONSENT_LOG_FILE=./logs/portal-consent.ndjson
CONSENT_LOG_TO_SHEETS=true
CONSENT_LOG_SHEET_NAME=ConsentLogs

# Portal session token (short-lived)
PORTAL_ACCESS_TOKEN_SECRET=REPLACE_WITH_64PLUS_CHAR_RANDOM_SECRET
PORTAL_ACCESS_TOKEN_TTL_SECONDS=900

# Staff gate (required in production)
# Format (plain): {"user1":"password1","user2":"password2"}
# Format (hash): {"user1":"scrypt$16384$8$1$<salt-b64>$<hash-b64>"}
STAFF_GATE_USERS_JSON={"frontdesk-1":"REPLACE_WITH_STRONG_PASSWORD"}
STAFF_SESSION_TOKEN_SECRET=REPLACE_WITH_DIFFERENT_64PLUS_CHAR_RANDOM_SECRET
STAFF_SESSION_TTL_SECONDS=28800
MAX_STAFF_PDF_BYTES=12582912
MAX_STAFF_BULK_ITEMS=25

# Staff audit trail
ENABLE_STAFF_AUDIT_LOG=true
STAFF_AUDIT_LOG_FILE=./logs/staff-audit.ndjson
AUDIT_LOG_MAX_BYTES=5242880
AUDIT_LOG_MAX_DAYS=30

# Staff lockout controls
STAFF_LOCKOUT_MAX_ATTEMPTS=5
STAFF_LOCKOUT_WINDOW_MS=900000
STAFF_LOCKOUT_DURATION_MS=900000
STAFF_LOCKOUT_SCOPE=user_ip

# Optional MFA (TOTP)
# Provide per-user base32 secrets (JSON map: user -> secret)
STAFF_MFA_REQUIRED=false
STAFF_MFA_SECRETS_JSON={}

# Service account JSON (backend secret only, never frontend)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Drive OAuth user creds (required when DRIVE_AUTH_MODE=oauth_user)
GOOGLE_OAUTH_CLIENT_ID=REPLACE_WITH_OAUTH_CLIENT_ID
GOOGLE_OAUTH_CLIENT_SECRET=REPLACE_WITH_OAUTH_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8085/oauth2/callback
GOOGLE_OAUTH_REFRESH_TOKEN=REPLACE_WITH_OAUTH_REFRESH_TOKEN
